---
import BreathingApp from '../components/ui/BreathingApp';
import '../styles/global.css';
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Respiración Guiada · Método NEURO™",
  "description": "Herramienta interactiva de respiración guiada de 1 a 5 minutos para regular el sistema nervioso y disminuir la ansiedad. Diseñado por Eliana Martínez.",
  "url": "https://psicoelia.com/respiracion",
  "provider": {
    "@type": "Person",
    "name": "Eliana Martínez"
  }
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Respiración Guiada (1 Min) · Método NEURO™</title>
    <meta name="description" content="Ejercicio interactivo de respiración guiada para regular tu sistema nervioso y encontrar la calma. Una herramienta gratuita de la neuropsicóloga Eliana Martínez." />
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#2d1f1f] m-0 p-0 overflow-x-hidden antialiased">
    <BreathingApp client:load />
  </body>
</html>
