---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/ui/Navbar';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import MethodSection from '../components/sections/MethodSection.astro';
import ProgramsSection from '../components/sections/ProgramsSection.astro';
import ResourcesSection from '../components/sections/ResourcesSection.astro';
import QuotesSlider from '../components/ui/QuotesSlider';
import TipsSection from '../components/sections/TipsSection.astro';
import ContactFooter from '../components/sections/ContactFooter.astro';
const schema = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "name": "Eliana Martínez · Neuropsicóloga",
  "image": "https://psicoelia.com/images/logo.jpeg",
  "url": "https://psicoelia.com",
  "telephone": "+573118909491",
  "email": "info.psicoelia@gmail.com",
  "description": "Neuropsicóloga y creadora del Método NEURO. Transformo pensamientos, emociones y vidas. Sesiones virtuales y programas online para mujeres.",
  "sameAs": [
    "https://www.instagram.com/psicoelia.co"
  ]
};
---

<Layout 
  title="Eliana Martínez · Neuropsicóloga" 
  description="Neuropsicóloga experta. Creadora del Método NEURO. Transformo pensamientos y emociones. Ofrezco sesiones 100% virtuales y programas online para mujeres."
  schema={schema}
>
  <Navbar client:load />
  
  <main>
    <HeroSection />
    <AboutSection />
    <MethodSection />
    <ProgramsSection />
    <ResourcesSection />
    
    <section id="frases" class="py-24 px-6 md:px-12 lg:px-20 bg-rose-pale text-center">
      <span class="inline-block text-[0.7rem] tracking-[0.2em] uppercase text-rose font-medium mb-3.5">
        Para tu alma
      </span>
      <h2 class="font-heading text-4xl lg:text-[3rem] font-normal text-brown-dark leading-[1.2] mb-12">
        Palabras que sanan
      </h2>
      <QuotesSlider client:visible />
    </section>

    <TipsSection />
    <ContactFooter />
  </main>
</Layout>
