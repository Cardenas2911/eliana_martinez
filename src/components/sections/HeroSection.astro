---
---
<section id="hero" class="min-h-screen flex items-center justify-center py-24 md:py-32 relative overflow-hidden px-6 md:px-12 lg:px-20">
  
  {/* Background Circles */}
  <div class="absolute rounded-full bg-rose-pale opacity-90 w-[300px] md:w-[500px] h-[300px] md:h-[500px] -top-20 md:-top-24 -right-20 md:-right-24 blur-3xl -z-10"></div>
  <div class="absolute rounded-full bg-rose-pale opacity-90 w-[200px] md:w-[300px] h-[200px] md:h-[300px] bottom-10 -left-10 md:-left-20 blur-2xl -z-10"></div>
  <div class="absolute rounded-full bg-beige-dark opacity-70 w-[120px] h-[120px] top-48 left-[45%] blur-xl -z-10"></div>

  <div class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 items-center gap-12 lg:gap-8 relative z-10">
    {/* Hero Text Content */}
    <div class="lg:pl-8 lg:pr-12 xl:pr-16 animate-in fade-in slide-in-from-bottom-8 duration-1000 fill-mode-both" itemScope itemType="http://schema.org/Person">
    <meta itemProp="name" content="Eliana Martínez" />
    <meta itemProp="jobTitle" content="Neuropsicóloga" />
    
    <span class="inline-block text-[0.72rem] tracking-[0.18em] uppercase text-rose font-medium border border-rose-light px-4 py-1.5 rounded-full mb-7">
      Neuropsicóloga · Método NEURO
    </span>
    
    <h1 class="font-heading text-5xl md:text-6xl lg:text-[4.2rem] xl:text-[4.8rem] font-normal leading-[1.1] text-brown-dark mb-6">
      Construye la mujer<br/>de tus <em class="italic text-rose">sueños</em>
    </h1>
    
    <p class="text-base text-text-soft leading-relaxed max-w-[420px] mb-10 font-light" itemProp="description">
      Transformo pensamientos, emociones y vidas. Sesiones virtuales y programas online para la mujer femenina, poderosa y libre, desde cualquier parte del mundo.
    </p>
    
    <div class="flex gap-4 flex-wrap">
      <a 
        href="#contacto" 
        class="bg-rose text-white px-8 py-3.5 rounded-full text-[0.82rem] tracking-[0.1em] uppercase font-medium transition-all duration-300 hover:bg-brown hover:-translate-y-0.5 shadow-[0_8px_24px_rgba(201,137,124,0.35)]"
      >
        Contáctame
      </a>
      <a 
        href="#metodo" 
        class="border-[1.5px] border-brown-mid text-brown px-8 py-3.5 rounded-full text-[0.82rem] tracking-[0.1em] uppercase font-medium transition-all duration-300 hover:bg-beige hover:-translate-y-0.5"
      >
        Conoce el método
      </a>
    </div>
  </div>

  {/* Hero Image / Placeholder */}
  <div class="hidden lg:flex items-center justify-center p-10 xl:p-16 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-200 fill-mode-both">
    <div class="relative w-full max-w-[340px] xl:max-w-[380px] aspect-[4/5]">
      <div class="absolute inset-5 top-5 left-5 bg-beige-dark rounded-[60%_40%_50%_50%/50%_50%_40%_60%] -z-10"></div>
      
      <div class="absolute inset-0 right-5 bottom-5 bg-rose-pale rounded-[60%_40%_50%_50%/50%_50%_40%_60%] flex flex-col items-center justify-center border-2 border-rose-light overflow-hidden shadow-lg">
        <img src="/images/hero-eliana.jpg" alt="Eliana Martínez - Neuropsicóloga" class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" />
      </div>

      <div class="absolute -bottom-5 -left-5 bg-white rounded-2xl p-4 lg:p-5 shadow-[0_8px_32px_rgba(0,0,0,0.1)] flex items-center gap-3">
        <div class="w-2.5 h-2.5 rounded-full bg-rose animate-pulse"></div>
        <div>
          <p class="text-[0.78rem] text-brown-dark font-medium leading-tight">Sesiones virtuales</p>
          <span class="text-[0.7rem] text-text-soft">Disponibles ahora</span>
        </div>
      </div>
    </div>
  </div>

  </div>
</section>
